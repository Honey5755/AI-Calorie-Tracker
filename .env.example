# NutriSnap AI provider keys. Copy this file to ".env", fill in ONE provider,
# then restart the dev server (env vars are baked in at bundle time):  npx expo start -c
# With no key the app runs in demo mode with realistic mock results.

# --- Option A: Anthropic Claude (vision) ---------------------------------
# Key from https://console.anthropic.com/settings/keys  (starts with "sk-ant-")
EXPO_PUBLIC_ANTHROPIC_API_KEY=
# Optional: override the model (default claude-opus-4-8). For lower cost/latency:
# EXPO_PUBLIC_CLAUDE_MODEL=claude-haiku-4-5

# --- Option B: Google Gemini (vision) ------------------------------------
# FREE key from https://aistudio.google.com/apikey  (starts with "AIza")
EXPO_PUBLIC_GEMINI_API_KEY=

# --- Provider selection (optional) ---------------------------------------
# Auto-picks Claude → Gemini → mock. Force one with: claude | gemini | mock
# EXPO_PUBLIC_AI_PROVIDER=claude
