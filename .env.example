# NutriSnap AI provider keys. Copy this file to ".env", fill in ONE provider,
# then restart the dev server (env vars are baked in at bundle time):  npx expo start -c
# With no key the app runs in demo mode with realistic mock results.

# --- Option A: Anthropic Claude (vision) ---------------------------------
# Key from https://console.anthropic.com/settings/keys  (starts with "sk-ant-")
EXPO_PUBLIC_ANTHROPIC_API_KEY=
# Optional: override the model (default claude-haiku-4-5 — cheap & fast).
# For more capability: EXPO_PUBLIC_CLAUDE_MODEL=claude-opus-4-8

# --- Option B: Google Gemini (vision) ------------------------------------
# FREE key from https://aistudio.google.com/apikey  (starts with "AIza")
EXPO_PUBLIC_GEMINI_API_KEY=

# --- Option C: NVIDIA NIM (vision) — FREE dev credits --------------------
# Key from https://build.nvidia.com  (starts with "nvapi-")
EXPO_PUBLIC_NVIDIA_API_KEY=
# Default is a free, hosted, multimodal model. Override with any other
# "Free Endpoint" multimodal model id shown on build.nvidia.com:
# EXPO_PUBLIC_NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct

# --- Provider selection (optional) ---------------------------------------
# Auto-picks Claude → Gemini → NVIDIA → mock. Force: claude | gemini | nvidia | mock
# EXPO_PUBLIC_AI_PROVIDER=nvidia
